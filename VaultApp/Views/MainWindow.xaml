<Window x:Class="VaultApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VaultApp.ViewModels"
        Title="VaultApp — Cofre de Senhas"
        Height="620" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="0,16,0,16">
            <DockPanel>

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="16,0,16,20">
                    <TextBlock Text="🔐 VaultApp"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>

                <!-- Botão nova entrada -->
                <Button DockPanel.Dock="Top"
                        Content="+ Nova entrada"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding NewEntryCommand}"
                        Margin="12,0,12,16"/>

                <!-- Label categorias -->
                <TextBlock DockPanel.Dock="Top"
                           Text="CATEGORIAS"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="16,0,0,8"/>

                <!-- Lista de categorias -->
                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Padding="8,6"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                CornerRadius="6"
                                                Padding="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HighlightBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Spacer -->
                <Grid DockPanel.Dock="Bottom"/>

                <!-- Botão travar -->
                <Button DockPanel.Dock="Bottom"
                        Content="🔒 Travar vault"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding LockCommand}"
                        Margin="12,8"/>

            </DockPanel>
        </Border>

        <!-- ==================== CONTEÚDO PRINCIPAL ==================== -->
        <Grid Grid.Column="1" Margin="24,20,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra de busca -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Style="{StaticResource DarkTextBox}"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Buscar entradas..."
                         Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                        Content="✕"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding ClearSearchCommand}"
                        Padding="12,8"
                        Visibility="{Binding SearchQuery, Converter={StaticResource StringToVisibilityConverter}}"/>
            </Grid>

            <!-- Lista de entradas -->
            <ListView Grid.Row="1"
                      ItemsSource="{Binding Entries}"
                      SelectedItem="{Binding SelectedEntry}"
                      Background="Transparent"
                      BorderThickness="0"
                      MouseDoubleClick="ListView_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Título" Width="200"
                                        DisplayMemberBinding="{Binding Title}"/>
                        <GridViewColumn Header="Usuário" Width="180"
                                        DisplayMemberBinding="{Binding Username}"/>
                        <GridViewColumn Header="Categoria" Width="120"
                                        DisplayMemberBinding="{Binding Category}"/>
                        <GridViewColumn Header="URL" Width="200"
                                        DisplayMemberBinding="{Binding Url}"/>
                        <GridViewColumn Header="Atualizado" Width="130">
                            <GridViewColumn.DisplayMemberBinding>
                                <Binding Path="UpdatedAt" StringFormat="{}{0:dd/MM/yyyy HH:mm}"/>
                            </GridViewColumn.DisplayMemberBinding>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="4,8"/>
                        <Setter Property="Cursor"     Value="Hand"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Toolbar de ações + status -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="📋 Copiar senha"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding CopyPasswordCommand}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                        Content="✏️ Editar"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding EditEntryCommand}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2"
                        Content="🗑 Excluir"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding DeleteEntryCommand}"
                        Foreground="{StaticResource DangerBrush}"/>

                <TextBlock Grid.Column="3"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
